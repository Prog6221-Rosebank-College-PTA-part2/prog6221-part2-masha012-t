<Window x:Class="IntegratedCollegeManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Assistant" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="PrimaryDark" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="SecondaryDark" Color="#16213e"/>
        <SolidColorBrush x:Key="AccentColor" Color="#e94560"/>
        <SolidColorBrush x:Key="HighlightColor" Color="#4ecdc4"/>
        <SolidColorBrush x:Key="TextLight" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8a9bb5"/>

        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c73e54"/>
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#a03245"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a4568"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopicChip" TargetType="Button">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="15" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CaretBrush" Value="{StaticResource HighlightColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#2d2d4a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track" CornerRadius="3">
                                <Border x:Name="PART_Indicator" 
                                        Background="{TemplateBinding Foreground}" 
                                        CornerRadius="3"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PrimaryDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryDark}" Padding="15">
            <StackPanel>
                <!-- ASCII Art Display -->
                <Border Background="#0a0a1a" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="◀" Style="{StaticResource SecondaryButton}" 
                                Width="35" Height="35" Click="PrevAscii_Click" FontSize="16"/>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock x:Name="AsciiTitle" Text="🛡️ SECURITY GUARDIAN" 
                                       Foreground="{StaticResource HighlightColor}" 
                                       FontWeight="Bold" FontSize="14" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="AsciiArtDisplay" 
                                       FontFamily="Consolas" FontSize="9" 
                                       Foreground="{StaticResource HighlightColor}" 
                                       TextAlignment="Center" Margin="0,5,0,0"
                                       Text="══════════════════════════════════════&#x0a;     🔒 CYBERSECURITY AWARENESS 🔒     &#x0a;        Stay Safe in Digital World        &#x0a;══════════════════════════════════════"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="▶" Style="{StaticResource SecondaryButton}" 
                                Width="35" Height="35" Click="NextAscii_Click" FontSize="16"/>
                    </Grid>
                </Border>

                <TextBlock Text="🛡️ CYBERSECURITY AWARENESS COHORT" 
                           FontSize="22" FontWeight="Bold" 
                           Foreground="{StaticResource AccentColor}" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Your AI-Powered Security Assistant" 
                           FontSize="13" Foreground="{StaticResource TextMuted}" 
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Area -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryDark}" 
                    CornerRadius="10" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Header -->
                    <Border Grid.Row="0" Background="#0f3460" Padding="12" 
                            CornerRadius="10,10,0,0">
                        <TextBlock Text="💬 CONVERSATION" 
                                   FontWeight="Bold" Foreground="{StaticResource AccentColor}" 
                                   FontSize="14"/>
                    </Border>

                    <!-- Chat Messages -->
                    <ListBox x:Name="ChatMessagesList" Grid.Row="1" 
                             Background="#0f3460" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,5,0,5" Padding="10" 
                                        CornerRadius="8"
                                        Background="{Binding Background}"
                                        HorizontalAlignment="{Binding Alignment}"
                                        MaxWidth="450">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Sender}" 
                                                   FontWeight="Bold" 
                                                   Foreground="{Binding SenderColor}"
                                                   FontSize="10"/>
                                        <TextBlock Text="{Binding Message}" 
                                                   TextWrapping="Wrap" 
                                                   Foreground="White"
                                                   FontSize="13"
                                                   Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}" 
                                                   FontSize="8" 
                                                   Foreground="#8a9bb5"
                                                   TextAlignment="Right"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Input Area -->
                    <Grid Grid.Row="2" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="MessageInput" Grid.Column="0" 
                                 MinHeight="60" MaxHeight="100"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 KeyDown="MessageInput_KeyDown"/>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <Button Content="📤 SEND" Style="{StaticResource PrimaryButton}"
                                    Height="40" Width="80" Click="SendMessage_Click"/>
                            <Button Content="🗑️ CLEAR" Style="{StaticResource SecondaryButton}"
                                    Height="35" Width="80" Margin="0,5,0,0" 
                                    Click="ClearChat_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Sidebar -->
            <ScrollViewer Grid.Column="1" Margin="5" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- User Info Card -->
                    <Border Background="{StaticResource SecondaryDark}" 
                            CornerRadius="10" Margin="0,0,0,10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="👤 USER PROFILE" 
                                       Foreground="{StaticResource AccentColor}" 
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBlock x:Name="UserNameDisplay" Text="Not set" 
                                           Foreground="{StaticResource TextLight}" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Interests:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBlock x:Name="UserInterestsDisplay" Text="None" 
                                           Foreground="{StaticResource TextLight}" FontSize="11" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Concerns:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBlock x:Name="UserConcernsDisplay" Text="None" 
                                           Foreground="{StaticResource TextLight}" FontSize="11" TextWrapping="Wrap"/>
                            </Grid>

                            <Border x:Name="MoodBadge" Background="#4ecdc4" 
                                    CornerRadius="15" Padding="8,4" Margin="0,10,0,0">
                                <TextBlock x:Name="MoodText" Text="Neutral" 
                                           Foreground="#1a1a2e" FontSize="11" 
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Voice Control Card -->
                    <Border Background="{StaticResource SecondaryDark}" 
                            CornerRadius="10" Margin="0,0,0,10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🎤 VOICE CONTROL" 
                                       Foreground="{StaticResource AccentColor}" 
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                            <Button x:Name="SpeakLastBtn" Content="🔊 Speak Last Response" 
                                    Style="{StaticResource PrimaryButton}"
                                    Click="SpeakLastResponse_Click"/>

                            <Button x:Name="VoiceInputBtn" Content="🎙️ Start Voice Input" 
                                    Style="{StaticResource SecondaryButton}" Margin="0,5,0,0"
                                    Click="StartVoiceInput_Click"/>

                            <ComboBox x:Name="VoiceSelector" Margin="0,10,0,0"
                                      Background="#0f3460" Foreground="{StaticResource TextLight}"
                                      SelectionChanged="VoiceSelector_SelectionChanged"/>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Volume" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="80"
                                        Foreground="{StaticResource HighlightColor}"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Speed" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                <Slider x:Name="RateSlider" Minimum="-10" Maximum="10" Value="0"
                                        Foreground="{StaticResource HighlightColor}"
                                        ValueChanged="RateSlider_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Statistics Card -->
                    <Border Background="{StaticResource SecondaryDark}" 
                            CornerRadius="10" Margin="0,0,0,10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📊 STATISTICS" 
                                       Foreground="{StaticResource AccentColor}" 
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Messages:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBlock x:Name="MessageCountDisplay" Text="0" 
                                           Foreground="{StaticResource HighlightColor}" 
                                           Grid.Column="1" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Session:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBlock x:Name="SessionDurationDisplay" Text="0 min" 
                                           Foreground="{StaticResource HighlightColor}" 
                                           Grid.Column="1" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Quick Actions Card -->
                    <Border Background="{StaticResource SecondaryDark}" 
                            CornerRadius="10" Margin="0,0,0,10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="⚡ QUICK ACTIONS" 
                                       Foreground="{StaticResource AccentColor}" 
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                            <Button Content="❓ Help Guide" Style="{StaticResource SecondaryButton}"
                                    Click="HelpGuide_Click" HorizontalAlignment="Stretch"/>
                            <Button Content="🧠 Reset Memory" Style="{StaticResource SecondaryButton}"
                                    Click="ResetMemory_Click" HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
                            <Button Content="💾 Export Chat" Style="{StaticResource SecondaryButton}"
                                    Click="ExportChat_Click" HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Topics Card -->
                    <Border Background="{StaticResource SecondaryDark}" 
                            CornerRadius="10" Margin="0,0,0,10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🔐 SECURITY TOPICS" 
                                       Foreground="{StaticResource AccentColor}" 
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                            <WrapPanel>
                                <Button Content="🔑 Passwords" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="🎣 Phishing" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="🦠 Malware" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="👁️ Privacy" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="🚨 Scams" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="🔄 Updates" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="💾 Backup" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                                <Button Content="📶 Wi-Fi" Style="{StaticResource TopicChip}" Click="Topic_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Sentiment Analysis Card -->
                    <Border Background="{StaticResource SecondaryDark}" 
                            CornerRadius="10" Margin="0,0,0,10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="📈 SENTIMENT ANALYSIS" 
                                       Foreground="{StaticResource AccentColor}" 
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                            <TextBlock Text="Positive" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            <ProgressBar x:Name="PositiveProgress" Foreground="#4ecdc4" Value="0"/>

                            <TextBlock Text="Neutral" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,8,0,0"/>
                            <ProgressBar x:Name="NeutralProgress" Foreground="#8a9bb5" Value="0"/>

                            <TextBlock Text="Worried" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,8,0,0"/>
                            <ProgressBar x:Name="WorriedProgress" Foreground="#ff6b6b" Value="0"/>

                            <TextBlock Text="Curious" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,8,0,0"/>
                            <ProgressBar x:Name="CuriousProgress" Foreground="#ffd93d" Value="0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0a0a1a" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBarText" Text="✅ Ready" 
                           Foreground="{StaticResource TextMuted}" FontSize="10"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="MemoryStatus" Text="🧠 Memory Active" 
                               Foreground="{StaticResource HighlightColor}" FontSize="10" Margin="10,0,0,0"/>
                    <TextBlock x:Name="VoiceStatus" Text="🔊 Voice Ready" 
                               Foreground="{StaticResource HighlightColor}" FontSize="10" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>